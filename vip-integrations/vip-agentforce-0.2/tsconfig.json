{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"jsx": "react-jsx",
		"lib": [ "DOM", "ES2020" ],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020"
	},
	"include": [ "assets/src/js/admin.tsx" ]
}
